{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "serena": {
            "type": "local",
            "enabled": true,
            "command": [
                "uvx",
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server",
                "--project",
                "/Users/lauranabuco/Trabalho/Agentes/opensquad"
            ]
        },
        "shadcn": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "shadcn@latest",
                "mcp"
            ]
        },
        "context-mode": {
            "type": "local",
            "enabled": true,
            "command": [
                "context-mode"
            ]
        }
    },
    "plugin": [
        "context-mode"
    ]
}